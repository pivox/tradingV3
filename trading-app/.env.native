# =============================================================
# trading-app/.env.native — Template pour le mode natif
#
# En mode natif (RUNTIME=native), Symfony ne reçoit pas les
# variables d'environnement injectées par Docker.
# Copiez ce fichier en .env.local et renseignez vos valeurs.
#
#   cp trading-app/.env.native trading-app/.env.local
#
# .env.local est gitignored. Ce fichier est tracké comme référence.
# =============================================================

APP_ENV=dev
APP_SECRET=d278711c5ab89bfbda10dd7d29427cf6

# ---- Base de données -----------------------------------------
# Port 5436 = port hôte exposé par le conteneur trading-app-db
DATABASE_URL=postgresql://postgres:password@localhost:5436/trading_app?serverVersion=15&charset=utf8
LOCK_DSN=postgresql://postgres:password@localhost:5436/trading_app

# ---- Redis ---------------------------------------------------
# Port 6379 = port hôte exposé par le conteneur redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_ORDER_WATCH_CHANNEL=watcher:order:watch

# ---- Bitmart API (reprendre les valeurs de .env) -------------
BITMART_API_KEY=
BITMART_SECRET_KEY=
BITMART_API_MEMO=
BITMART_BASE_URL=https://api-cloud-v2.bitmart.com
BITMART_PRIVATE_API_URL=https://api-cloud-v2.bitmart.com
BITMART_PUBLIC_API_URL=https://api-cloud-v2.bitmart.com
BITMART_WS_PRIVATE_URL=wss://openapi-ws-v2.bitmart.com/api?protocol=1.1
BITMART_WS_DEVICE=
BITMART_RATE_PUBLIC_KLINE=9/2

# ---- Niveaux de log ------------------------------------------
LOG_LEVEL_MAIN=info
LOG_LEVEL_SIGNALS=info
LOG_LEVEL_POSITIONS=info
LOG_LEVEL_INDICATORS=info
LOG_LEVEL_HIGHCONVICTION=info
LOG_LEVEL_PIPELINE_EXEC=info
LOG_LEVEL_GLOBAL_SEVERITY=error
MTF_LOG_LEVEL=debug
ASYNC_LOGGING_ENABLED=1

# ---- Divers --------------------------------------------------
DEFAULT_URI=http://localhost:8082
MAILER_DSN=smtp://localhost
MESSENGER_TRANSPORT_DSN=doctrine://default?queue_name=log_messages
WS_WORKER_SHARED_SECRET=change-me
ORDER_TIMEOUT_SWITCH_DURATION=15m
