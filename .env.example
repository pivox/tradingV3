# =============================================================
# TradingV3 — Configuration d'environnement
# Copiez ce fichier en .env et renseignez vos valeurs.
# .env est gitignored ; ce fichier est tracké.
# =============================================================

# ---- Mode d'exécution ----------------------------------------
# docker  → Les commandes PHP s'exécutent dans le conteneur Docker (défaut)
# native  → Les commandes PHP s'exécutent directement sur la machine hôte
#
# Changer via Makefile : make env-native  /  make env-docker
# Changer via CLI      : RUNTIME=native make <cible>
RUNTIME=docker

# ---- Bitmart API ---------------------------------------------
BITMART_API_KEY=
BITMART_SECRET_KEY=
BITMART_API_MEMO=
BITMART_BASE_URL=https://api-cloud-v2.bitmart.com
BITMART_PRIVATE_API_URL=https://api-cloud-v2.bitmart.com
BITMART_PUBLIC_API_URL=https://api-cloud-v2.bitmart.com
BITMART_WS_PRIVATE_URL=wss://openapi-ws-v2.bitmart.com/api?protocol=1.1
BITMART_WS_DEVICE=
BITMART_RATE_PUBLIC_KLINE=9/2

# ---- Base de données --------------------------------------------
# Cette variable est injectée dans le conteneur par docker-compose.
#
# Mode docker (défaut) : hôte = 'trading-app-db' (réseau interne Docker)
# Mode native          : hôte = 'localhost', port = 5436 (port exposé)
#
# Laissez la valeur docker-mode ci-dessous si RUNTIME=docker.
# En mode natif, cette variable est ignorée : DATABASE_URL est lu
# directement depuis trading-app/.env.local (voir .env.native).
TRADING_APP_DATABASE_URL=postgresql://postgres:password@trading-app-db:5432/trading_app?serverVersion=15&charset=utf8

# ---- Secrets partagés ----------------------------------------
WS_WORKER_SHARED_SECRET=change-me
REDIS_ORDER_WATCH_CHANNEL=watcher:order:watch
ORDER_TIMEOUT_SWITCH_DURATION=15m

# ---- Hyperliquid testnet (disabled by default) ----------------
DEMO_TRADING_ENABLED=0
HYPERLIQUID_TESTNET_TRADING_ENABLED=0
HYPERLIQUID_SIGNER_BROADCAST_ENABLED=0
HYPERLIQUID_TESTNET_ACCOUNT_ADDRESS=
HYPERLIQUID_TESTNET_AGENT_ADDRESS=
HYPERLIQUID_TESTNET_AGENT_PRIVATE_KEY=
HYPERLIQUID_SIGNER_AUTH_TOKEN=

# ---- OKX private WebSocket observability (disabled by default) --
# Credentials must belong to an OKX demo API key with read-only permissions.
OKX_ENV=demo
OKX_DEMO_API_KEY=
OKX_DEMO_API_SECRET=
OKX_DEMO_API_PASSPHRASE=
OKX_API_BASE_URI=https://eea.okx.com
OKX_WS_PUBLIC_URI=wss://wseeapap.okx.com:8443/ws/v5/public
OKX_WS_PRIVATE_URI=wss://wspap.okx.com:8443/ws/v5/private?brokerId=9999
OKX_WS_BUSINESS_URI=wss://wspap.okx.com:8443/ws/v5/business
OKX_SIMULATED_TRADING=1
OKX_DEMO_TRADING_ENABLED=0
OKX_LIVE_ENABLED=0
REDIS_HOST=redis
REDIS_PORT=6379
